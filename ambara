#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
PYTHON="$ROOT/.venv/bin/python"
API_SRC="$ROOT/apps/api/src"

case "${1:-help}" in
  ingest)     shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app ingest "$@" ;;
  sync)       shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app sync "$@" ;;
  export)     shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app export "$@" ;;
  redraft)    shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app redraft "$@" ;;
  train)      shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app train "$@" ;;
  delete-run) shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app delete-run "$@" ;;
  api)        shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app api "$@" ;;
  purge-api-cache) shift; exec env PYTHONPATH="$API_SRC" "$PYTHON" -m ports.cli.app purge-api-cache "$@" ;;
  editor)
    shift
    echo "Starting transcript editor at http://localhost:3000"
    cd "$ROOT/apps/web"
    exec npx next dev
    ;;
  setup)     python3 -m venv .venv && .venv/bin/pip install --upgrade pip && make install ;;
  install)   exec make install ;;
  *)         echo "Usage: ./ambara <command> [options]"
             echo ""
             echo "Commands:"
             echo "  ingest          Download + extract + sync"
             echo "  sync            Sync extraction run to Supabase"
             echo "  export          Export corrected clips as a training dataset"
             echo "  redraft         Re-transcribe pending clips"
              echo "  train           Fine-tune Whisper on exported training data"
              echo "  delete-run      Delete a run and all its data from Supabase"
              echo "  api             Start the API worker"
              echo "  purge-api-cache Clear API model and bytecode caches"
              echo "  editor          Start the web editor"
             echo ""
             echo "Setup:"
             echo "  setup           Create venv and install all packages"
             echo "  install         Install local packages (editable)"
             echo ""
             echo "Examples:"
             echo "  ./ambara ingest 'https://youtube.com/watch?v=...' -l church-mass --device mps"
             echo "  ./ambara export --run-id <id> --run-id <id>"
             echo "  ./ambara redraft --run-id <id> --model models/whisper-mg-v1/model"
             ;;
esac
